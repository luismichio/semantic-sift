# Semantic-Sift Environment Template
# Copy this to .env and fill in your values.
# DO NOT COMMIT THE ACTUAL .env FILE.

# GitHub MCP Token (Compromised token has been revoked)
# Create a new one at https://github.com/settings/tokens
GITHUB_MCP_PAT="your_new_github_token_here"

# Vercel Access Token
# Create one at https://vercel.com/account/tokens
VERCEL_ACCESS_TOKEN="your_vercel_token_here"
