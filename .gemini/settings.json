{
  "general": {
    "maxAttempts": 3
  },
  "modelConfigs": {
    "default": {
      "generateContentConfig": {
        "thinkingConfig": {
          "thinkingBudget": 2048,
          "thinkingLevel": "LOW"
        }
      }
    }
  },
  "telemetry": {
    "enabled": true,
    "target": "local",
    "outfile": ".gemini/telemetry.log"
  },
  "tools": {
    "shell": {
      "inactivityTimeout": 60
    }
  },
  "experimental": {
    "modelSteering": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "context-mode-session",
            "type": "command",
            "command": "context-mode hook gemini sessionstart"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "semantic-sifter",
            "type": "command",
            "command": "C:/Users/luism/Workbench/GitHub/semantic-sift/venv312/Scripts/python.exe C:/Users/luism/Workbench/GitHub/semantic-sift/sift_hook.py"
          },
          {
            "name": "context-mode-index",
            "type": "command",
            "command": "context-mode hook gemini aftertool"
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "name": "context-mode-compress",
            "type": "command",
            "command": "context-mode hook gemini precompress"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context-mode": {
      "command": "context-mode",
      "args": []
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "C:/Users/luism/Workbench/GitHub/semantic-sift"
      ]
    },
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ***REDACTED***"
      }
    },
    "semantic-sift": {
      "command": "C:/Users/luism/Workbench/GitHub/semantic-sift/venv312/Scripts/python.exe",
      "args": [
        "C:/Users/luism/Workbench/GitHub/semantic-sift/server.py"
      ]
    }
  }
}
